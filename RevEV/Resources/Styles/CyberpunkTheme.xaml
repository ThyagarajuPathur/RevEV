<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Cyberpunk Typography Styles -->
    <Style x:Key="HeroTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OrbitronBlack" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="TextColor" Value="{StaticResource NeonCyan}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OrbitronBold" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="TextColor" Value="{StaticResource NeonCyan}" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OrbitronBold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource GhostWhite}" />
    </Style>

    <Style x:Key="DataValueStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OrbitronBold" />
        <Setter Property="FontSize" Value="64" />
        <Setter Property="TextColor" Value="{StaticResource NeonCyan}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="DataLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="Orbitron" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource Gray400}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="CharacterSpacing" Value="2" />
    </Style>

    <Style x:Key="TerminalTextStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TerminalGreen}" />
    </Style>

    <Style x:Key="SpeedDisplayStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OrbitronBlack" />
        <Setter Property="FontSize" Value="96" />
        <Setter Property="TextColor" Value="{StaticResource PlasmaPink}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="UnitLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="Orbitron" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Gray400}" />
        <Setter Property="CharacterSpacing" Value="3" />
    </Style>

    <!-- Cyberpunk Card Styles -->
    <Style x:Key="CyberpunkCardStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource DeepSpace}" />
        <Setter Property="BorderColor" Value="{StaticResource GridGray}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="SelectedCardStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource DeepSpace}" />
        <Setter Property="BorderColor" Value="{StaticResource NeonCyan}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <!-- Neon Button Styles -->
    <Style x:Key="NeonCyanButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource NeonCyan}" />
        <Setter Property="BorderColor" Value="{StaticResource NeonCyan}" />
        <Setter Property="BorderWidth" Value="2" />
        <Setter Property="FontFamily" Value="OrbitronBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20,12" />
    </Style>

    <Style x:Key="NeonPinkButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource PlasmaPink}" />
        <Setter Property="BorderColor" Value="{StaticResource PlasmaPink}" />
        <Setter Property="BorderWidth" Value="2" />
        <Setter Property="FontFamily" Value="OrbitronBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20,12" />
    </Style>

    <Style x:Key="FilledCyanButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource NeonCyan}" />
        <Setter Property="TextColor" Value="{StaticResource VoidBlack}" />
        <Setter Property="FontFamily" Value="OrbitronBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20,12" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource WarningRed}" />
        <Setter Property="BorderColor" Value="{StaticResource WarningRed}" />
        <Setter Property="BorderWidth" Value="2" />
        <Setter Property="FontFamily" Value="OrbitronBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20,12" />
    </Style>

    <!-- Status Indicator Styles -->
    <Style x:Key="ConnectedIndicatorStyle" TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource TerminalGreen}" />
        <Setter Property="WidthRequest" Value="12" />
        <Setter Property="HeightRequest" Value="12" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style x:Key="DisconnectedIndicatorStyle" TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource WarningRed}" />
        <Setter Property="WidthRequest" Value="12" />
        <Setter Property="HeightRequest" Value="12" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <!-- Divider Style -->
    <Style x:Key="NeonDividerStyle" TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource GridGray}" />
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="HorizontalOptions" Value="FillAndExpand" />
    </Style>

    <!-- Connection Status Border -->
    <Style x:Key="StatusBorderStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource DeepSpace}" />
        <Setter Property="Stroke" Value="{StaticResource GridGray}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="20" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
